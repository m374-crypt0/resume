---
type Heading = { depth: number; slug: string; text: string }
type Props = { headings: Heading[] }

const { headings } = Astro.props
const entries = headings.filter(h => h.depth <= 3)
---

<nav class="toc no-print" aria-label="Table of contents">
  <div class="toc-trigger" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </div>

  <div class="toc-panel">
    {entries.map(h => (
      <a href={`#${h.slug}`} class={`toc-entry toc-h${h.depth}`}>
        {h.text}
      </a>
    ))}
  </div>
</nav>

<style>
  .toc {
    position: fixed;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 100;
  }

  .toc-trigger {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: var(--color-border);
    color: var(--color-body);
    opacity: 0.6;
    cursor: default;
    transition: opacity 0.15s;
  }

  .toc:hover .toc-trigger {
    opacity: 1;
  }

  .toc-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 14rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.5rem 0;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);

    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, visibility 0.15s, transform 0.15s;
  }

  .toc:hover .toc-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .toc-entry {
    display: block;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.1s;
  }

  .toc-entry:hover {
    color: var(--color-h3);
  }

  .toc-h2 {
    padding: 0.2rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-strong);
  }

  .toc-h3 {
    padding: 0.15rem 1rem 0.15rem 1.75rem;
    font-size: 0.75rem;
    color: var(--color-body);
  }
</style>
