---
import { Image } from 'astro:assets'
import picture from '../assets/sebastien-levy.jpeg'

export type Props = {
  name: string,
  title: string
}

const {name, title} = Astro.props
---
<header class="flex items-center gap-8 max-w-5xl mx-auto px-6 py-10">
  <Image src={picture} width={160} alt={'sebastien-levy-picture'} class="rounded-full shrink-0" />
  <div>
    <h1 class="text-5xl font-bold" style="color: var(--color-h2)">{name}</h1>
    <p class="text-2xl mt-2" style="color: var(--color-h3)">{title}</p>
  </div>
</header>
